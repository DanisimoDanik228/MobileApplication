<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MobileApplication" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Тема для сплеш-экрана -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Цвет фона -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- Иконка (логотип) в центре -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <!-- Тема, которая применится ПОСЛЕ загрузки (ваша основная тема приложения) -->
        <item name="postSplashScreenTheme">@style/Theme.MobileApplication</item>
    </style>
</resources>